# xAI Grok API (required for /chat, /test-chat, SMS agent)
XAI_API_KEY=

# Optional; omit to use default grok-4
# XAI_CHAT_MODEL=grok-4

# Supabase (required for persistence + knowledge retrieval)
SUPABASE_URL=https://vapnbelrpaxeafospalc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Next.js quote viewer (public anon key + same project URL — never use service role in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://vapnbelrpaxeafospalc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio (required for SMS webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# From number verified in Twilio (E.164)
TWILIO_PHONE_NUMBER=+18014590886

# Optional: validate Twilio request signatures in production (true/false)
TWILIO_VALIDATE_SIGNATURE=false

# When validating signatures: full URL configured on the Twilio webhook (must match what Twilio signed)
TWILIO_WEBHOOK_URL=

# Base URL for estimate pdf_link in APIs (SMS/email links); omit to use inbound request Host
PUBLIC_BASE_URL=

# PDF footer / internal references
FORTIS_SUPPORT_EMAIL=edge-support@fortisedge.internal
FORTIS_SUPPORT_PHONE=(801) 459-0886
FORTIS_PORTAL_ROLLOUT_PCT=73
FORTIS_PORTAL_PHASE=Wave 3
